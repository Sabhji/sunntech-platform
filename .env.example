# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sunntech"
NEXT_PUBLIC_DATABASE_URL="postgresql://user:password@localhost:5432/sunntech"

# Authentication
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# API Keys (if using external services)
NEXT_PUBLIC_API_URL="https://api.sunntech.in"

# Email Service (if using)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"

# Redis (for production rate limiting)
REDIS_URL="redis://localhost:6379"

# Security
ALLOWED_ORIGINS="http://localhost:3000,https://www.sunntech.in"
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_WINDOW_MS="900000"

# Feature Flags
NEXT_PUBLIC_ENABLE_REGISTRATION="true"
NEXT_PUBLIC_ENABLE_SOCIAL_LOGIN="false"
